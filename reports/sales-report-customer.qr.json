{
    "title": "Satış Raporu (Müşteri Bazında)",
    "description": "Müşteri bazında iki tarih arasındaki satışların raporu",
    "dataSource": {
        "connectionName": "logoDb",
        "query": {
            "sql": [

                "SELECT ",
                    "sr.CUSTOMER_NAME, ",
                    "SUM(sr.AMOUNT_KG) as AMOUNT_KG, ",
                    "SUM(sr.AMOUNT_TL) as AMOUNT_TL ",
                "FROM  ",
                    "V_SALES_REPORT sr ",
                "WHERE ",
                    "sr.SALES_PERSON_ID = :SALES_PERSON_CODE ",
                    "AND sr.INVOICE_DATE >= :BEGIN_DATE ", 
                    "AND sr.INVOICE_DATE <= :END_DATE ",
               "GROUP BY ",
                    "sr.CUSTOMER_NAME ",
                "ORDER BY ",
                    "sr.CUSTOMER_NAME"
            ],
            "parameters": [
                {
                    "id": "SALES_PERSON_CODE",
                    "type": "userVariable",
                    "source": "ERP_USER_ID"
                },
                {
                    "id": "BEGIN_DATE",
                    "type": "date",
                    "description": "Başlangıç Tarihi"
                },
                {
                    "id": "END_DATE",
                    "type": "date",
                    "description": "Bitiş Tarihi"
                }
            ]
        }
    },
    "columns": [
        {
            "name": "CUSTOMER_NAME",
            "header": "Müşteri Unvanı",
            "type": "string",
            "alignment": "left"
        },
        {
            "name": "AMOUNT_KG",
            "header": "Miktar (Kg)",
            "type": "number",
            "alignment": "right",
            "decimalPlaces": 0,
            "aggrFuncInSum": "sum"
        },
        {
            "name": "AMOUNT_TL",
            "header": "Tutar (TL)",
            "type": "number",
            "alignment": "right",
            "decimalPlaces": 0,
            "aggrFuncInSum": "sum",
            "visible": {
                "expr": "(auth) => auth > 5",
                "parameters": [
                    {
                        "id": "auth",
                        "type": "userVariable",
                        "source": "AUTH"
                    }
                ]
            }
        },
        {
            "name": "UNIT_PRICE_TL",
            "header": "Birim Fiyat (TL)",
            "type": "number",
            "alignment": "right",
            "decimalPlaces": 2,
            "function": {
                "expr": "(m, t) => m > 0 ? t / m : 0",
                "parameters": [
                    {
                        "id": "m",
                        "type": "column",
                        "source": "AMOUNT_KG"
 },
                    {
                        "id": "t",
                        "type": "column",
                        "source": "AMOUNT_TL"
                    }
                ]
            },
            "aggrFuncInSum": "func",
            "visible": {
                "expr": "(auth) => auth > 5",
                "parameters": [
                    {
                        "id": "auth",
                        "type": "userVariable",
                        "source": "AUTH"
                    }
                ]
            }
        }
    ],

    "subReports": [
        {
            "id": "sales-report-product",
            "parameters": [
                {
                    "id": "CUSTOMER_NAME",
                    "type": "column",
                    "source": "CUSTOMER_NAME"
                }
            ]
        },
        {
            "id": "sales-report-customer-invoice",
            "parameters": [
                {
                    "id": "CUSTOMER_NAME",
                    "type": "column",
                    "source": "CUSTOMER_NAME"
                }
            ]
        }
    ]
}
